# ==========================================
# .NET Core / C# (Binaries & Build Outputs)
# ==========================================
[Bb]in/
[Oo]bj/
*.suo
*.user
*.sln.docstates
*.pyc

# Маппинги компилятора и локальные папки паблиша
[Log]/
[Pp]ublish/
/publish/
/_work/

# ==========================================
# JetBrains Rider & WebStorm & IntelliJ
# ==========================================
.idea/
*.sln.iml
## Игнорируем локальные настройки тасок и словарей Rider, 
## но оставляем общие настройки проекта (если нужно шарить конфигурации запуска)
.idea/**/workspace.xml
.idea/**/tasks.xml
.idea/**/usage.statistics.xml
.idea/**/dictionaries
.idea/**/shelf

# ==========================================
# Visual Studio & MSBuild
# ==========================================
.vs/
*.userosscache
*.sln.DotSettings.user

# ==========================================
# Docker & Containers
# ==========================================
.dockerignore
# Разрешаем сам dockerignore, но глушим локальные файлы сборки, если они создаются на хосте
.docker/

# ==========================================
# Конфигурации, Секреты и Окружение (CRITICAL)
# ==========================================
# Файлы окружения
*.env
*.env.local
*.env.*.local
.env
.env.development

# Локальные секреты .NET (appsettings для разработки)
**/appsettings.Development.json
**/appsettings.Local.json
secrets.json

# ==========================================
# Зависимости и пакеты (Nuget & NPM)
# ==========================================
# Nuget папка реставрации (если используется локальный воркспейс)
.nuget/
packages/
*.nuget.props
*.nuget.targets

# Если в модулях монолита будут фронтенд-части (микрофронты или админки)
node_modules/
/npm-debug.log*
/yarn-error.log*
.pnpm-debug.log*

# ==========================================
# Логи и Временные файлы системы
# ==========================================
*.log
*.bak
*.tmp
*.swp
Thumbs.db
.DS_Store